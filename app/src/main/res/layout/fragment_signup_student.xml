<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="16dp"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:paddingTop="16dp"
    tools:context=".SignupStudentFragment">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:ignore="UselessParent">

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:text="@string/create_student_account"
            android:textAllCaps="true"
            android:textColor="@color/colorPrimary"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>



        <EditText
            android:id="@+id/student_signup_name"
            android:layout_width="fill_parent"
            android:hint="@string/enter_your_name"
            android:textColorHint="@color/colorPrimary"
            android:layout_height="38dp"
            android:layout_marginBottom="10dp"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="14sp"
            android:importantForAutofill="no" />


        <EditText
            android:id="@+id/student_signup_lastname"
            android:layout_width="fill_parent"
            android:hint="@string/enter_your_last_name"
            android:textColorHint="@color/colorPrimary"
            android:layout_height="38dp"
            android:layout_marginBottom="10dp"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="14sp"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/student_signup_email"
            android:layout_width="fill_parent"
            android:hint="@string/enter_your_email"
            android:textColorHint="@color/colorPrimary"
            android:layout_height="38dp"
            android:layout_marginBottom="10dp"
            android:inputType="textEmailAddress"
            android:singleLine="true"
            android:textSize="14sp"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/student_signup_email_of_parent"
            android:layout_width="fill_parent"
            android:hint="@string/enter_your_parent_s_email"
            android:textColorHint="@color/colorPrimary"
            android:layout_height="38dp"
            android:layout_marginBottom="10dp"
            android:inputType="textEmailAddress"
            android:singleLine="true"
            android:textSize="14sp"
            android:importantForAutofill="no"/>


        <EditText
            android:id="@+id/student_signup_phone"
            android:layout_width="fill_parent"
            android:hint="@string/your_phone"
            android:textColorHint="@color/colorPrimary"
            android:layout_height="38dp"
            android:layout_marginBottom="10dp"
            android:inputType="phone"
            android:singleLine="true"
            android:textSize="14sp"
            android:importantForAutofill="no" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center">
            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="3dp"
                android:paddingEnd="3dp"
                android:text="@string/grade"
                android:textAllCaps="true"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/student_signup_grade"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="1dp"
                android:entries="@array/grade"
                android:textSize="10sp" />

            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="3dp"
                android:paddingEnd="3dp"
                android:text="@string/age"
                android:textAllCaps="true"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/student_signup_age"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="1dp"
                android:entries="@array/age"
                android:textSize="12sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/student_signup_password"
            android:layout_width="fill_parent"
            android:hint="@string/password"
            android:textColorHint="@color/colorPrimary"
            android:layout_height="38dp"
            android:layout_marginBottom="10dp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:textSize="14sp"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/student_signup_confirm_password"
            android:layout_width="fill_parent"
            android:hint="@string/confirm_password"
            android:textColorHint="@color/colorPrimary"
            android:layout_height="38dp"
            android:layout_marginBottom="10dp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:textSize="14sp"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/student_signup_account_type"
            android:layout_width="fill_parent"
            android:layout_height="38dp"
            android:text="@string/student"
            android:layout_marginBottom="10dp"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="14sp"
            android:visibility="gone"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/student_signup_button"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:background="@color/colorPrimary"
            android:paddingBottom="1dp"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:paddingTop="1dp"
            android:text="@string/register"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="13sp" />
    </LinearLayout>




</RelativeLayout>